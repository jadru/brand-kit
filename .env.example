# ==============================================
# BrandKit Environment Variables
# ==============================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control

# ==============================================
# App Configuration
# ==============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================
# Supabase (Required)
# ==============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJ...

# Service role key for server-side operations (admin access)
# Keep this secret! Never expose on the client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ==============================================
# AI Services (Required)
# ==============================================
# Claude API for headline/copy generation
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# FAL AI for icon generation
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=...

# ==============================================
# LemonSqueezy (Required for payments)
# ==============================================
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=...
LEMONSQUEEZY_STORE_ID=...
LEMONSQUEEZY_WEBHOOK_SECRET=...

# Pro plan variant IDs from your LemonSqueezy products
LEMONSQUEEZY_PRO_VARIANT_ID=...
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=...

# ==============================================
# Email (Optional - for transactional emails)
# ==============================================
# Resend for transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=BrandKit <noreply@brandkit.ai>

# ==============================================
# Internal API Security (Optional)
# ==============================================
# Used for internal API routes that require authentication
INTERNAL_API_KEY=your-secure-random-string

# ==============================================
# Analytics (Optional)
# ==============================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# Vercel Analytics (auto-populated in Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=...

# ==============================================
# SEO Verification (Optional)
# ==============================================
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=...
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=...
